{
  "name": "@md-business/chrome-extension",
  "version": "0.5.0",
  "private": true,
  "description": "Markdown-first business document viewer for Chrome — open a Markdown file, preview as 適格請求書, save as PDF.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build && node scripts/post-build.mjs",
    "release": "pnpm build && node scripts/make-release.mjs",
    "release:patch": "node scripts/bump-version.mjs patch && pnpm release",
    "release:minor": "node scripts/bump-version.mjs minor && pnpm release",
    "release:major": "node scripts/bump-version.mjs major && pnpm release",
    "dev": "vite build --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run --coverage"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@md-business/core": "workspace:*",
    "@md-business/renderer-pdf": "workspace:*",
    "@md-business/schema-invoice": "workspace:*",
    "@md-business/schema-spec": "workspace:*",
    "buffer": "^6.0.3",
    "codemirror": "^6.0.2",
    "dompurify": "^3.2.0",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@fontsource/noto-serif-jp": "^5.2.8",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^29.1.1",
    "pagedjs": "^0.4.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
