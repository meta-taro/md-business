{
  "manifest_version": 3,
  "name": "md-business — Markdown 業務文書ビューワー",
  "short_name": "md-business",
  "description": "Markdown ファースト × 業務文書ビューワー。.md を開いて適格請求書・基本設計書として描画し、PDF として保存します。Mermaid 図・免税事業者モード対応。",
  "version": "0.5.0",
  "author": "md-business contributors",
  "homepage_url": "https://github.com/meta-taro/md-business",
  "minimum_chrome_version": "120",
  "permissions": ["storage"],
  "host_permissions": ["file:///*"],
  "action": {
    "default_title": "md-business: Open Markdown file",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["file:///*/*.md", "file:///*.md"],
      "js": ["content/file-md.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/viewer/index.html",
        "src/popup/index.html",
        "assets/*",
        "chunks/*",
        "styles/*",
        "templates/*",
        "templates/**/*",
        "vendor/*"
      ],
      "matches": ["file:///*", "<all_urls>"]
    }
  ]
}
