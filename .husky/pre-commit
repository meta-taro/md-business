#!/usr/bin/env sh
# コミット前ゲート — 内部参照スキャン / lint / typecheck / unit test。
# turbo がキャッシュするので変更パッケージのみ再実行される。
set -e

echo "[pre-commit] OSS 内部参照スキャン..."
node scripts/oss-guard/check-staged.mjs

echo "[pre-commit] lint..."
pnpm -w run lint

echo "[pre-commit] typecheck..."
pnpm -w run typecheck

echo "[pre-commit] tests..."
pnpm -w run test:run

echo "[pre-commit] OK"
