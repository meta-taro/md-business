{
  "name": "@md-business/renderer-pdf",
  "version": "0.0.0",
  "private": false,
  "description": "PDF renderer for md-business invoices — pure HTML/CSS generator plus a Paged.js browser helper for A4 portrait output.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./styles/invoice.css": "./src/styles/invoice.css",
    "./styles/spec.css": "./src/styles/spec.css",
    "./styles/test-spec.css": "./src/styles/test-spec.css",
    "./styles/db-spec.css": "./src/styles/db-spec.css",
    "./styles/nosql-db-spec.css": "./src/styles/nosql-db-spec.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@md-business/schema-db-spec": "workspace:*",
    "@md-business/schema-invoice": "workspace:*",
    "@md-business/schema-nosql-db-spec": "workspace:*",
    "@md-business/schema-spec": "workspace:*",
    "@md-business/schema-test-spec": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.50",
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@vitest/coverage-v8": "^2.1.8",
    "pdf-parse": "^1.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
