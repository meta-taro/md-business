{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://md-business.dev/schemas/api-spec/v1.json",
  "title": "md-business api-spec (API 詳細設計書) frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "documentNumber",
    "title",
    "version",
    "issueDate",
    "status",
    "protocol",
    "auth",
    "authors",
    "endpoints"
  ],
  "properties": {
    "schema": { "const": "api-spec/v1" },
    "documentNumber": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "issueDate": { "type": "string", "format": "date" },
    "status": { "enum": ["draft", "review", "approved", "deprecated"] },
    "protocol": { "enum": ["rest", "rpc", "graphql"] },
    "auth": { "enum": ["none", "bearer", "apiKey", "oauth2", "basic"] },
    "baseUrl": { "type": "string", "minLength": 1 },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/person" }
    },
    "reviewers": {
      "type": "array",
      "items": { "$ref": "#/$defs/person" }
    },
    "relatedDocs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "endpoints": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/endpoint" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/error" }
    },
    "theme": { "type": "string", "minLength": 1 },
    "fileName": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "person": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "role": { "type": "string" }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "enum": [
            "string",
            "integer",
            "number",
            "boolean",
            "array",
            "object",
            "date",
            "datetime"
          ]
        },
        "required": { "type": "boolean" },
        "description": { "type": "string" },
        "dbRef": { "type": "string", "pattern": "^[^#]+#[^#]+$" },
        "format": { "type": "string", "minLength": 1 },
        "of": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field" }
        }
      }
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contentType", "fields"],
      "properties": {
        "contentType": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field" }
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pathParams": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        },
        "queryParams": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        },
        "headers": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        },
        "body": { "$ref": "#/$defs/body" }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "integer", "minimum": 100, "maximum": 599 },
        "description": { "type": "string" },
        "body": { "$ref": "#/$defs/body" },
        "errorRef": { "type": "string", "minLength": 1 }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operationId", "method", "path", "responses"],
      "properties": {
        "operationId": { "type": "string", "minLength": 1 },
        "method": {
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
        },
        "path": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "auth": { "enum": ["none", "bearer", "apiKey", "oauth2", "basic"] },
        "request": { "$ref": "#/$defs/request" },
        "responses": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/response" }
        },
        "deprecated": { "type": "boolean" }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "httpStatus", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "httpStatus": { "type": "integer", "minimum": 100, "maximum": 599 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
